{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/auth/login",    "destination": "/api/auth/login" },
    { "source": "/api/health",        "destination": "/api/health" },
    { "source": "/api/items",         "destination": "/api/items/index" },
    { "source": "/api/items/:id",     "destination": "/api/items/[id]" },
    { "source": "/api/offers",        "destination": "/api/offers/index" },
    { "source": "/api/offers/:id",    "destination": "/api/offers/[id]" },
    { "source": "/api/services",      "destination": "/api/services/index" },
    { "source": "/api/services/:id",  "destination": "/api/services/[id]" },
    { "source": "/api/groups",        "destination": "/api/groups/index" },
    { "source": "/api/groups/:id",    "destination": "/api/groups/[id]" },
    { "source": "/api/settings",      "destination": "/api/settings/index" },
    { "source": "/(.*)",              "destination": "/index.html" }
  ]
}
